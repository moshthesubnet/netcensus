# Proxmox API credentials — copy to .env and fill in your values
# Token-based auth (recommended):
PROXMOX_HOST=192.168.1.100
PROXMOX_USER=root@pam
PROXMOX_TOKEN_ID=root@pam!scanner
PROXMOX_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Password-based auth (alternative):
# PROXMOX_HOST=192.168.1.100
# PROXMOX_USER=root@pam
# PROXMOX_PASSWORD=yourpassword

# Set to "true" only if Proxmox has a valid CA-signed cert:
PROXMOX_VERIFY_SSL=false
