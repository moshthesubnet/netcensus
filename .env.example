# ── OPNsense (required for cross-VLAN ARP/NDP discovery) ───────────────────────
OPNSENSE_URL=https://192.168.1.1
OPNSENSE_KEY=your_api_key_here
OPNSENSE_SECRET=your_api_secret_here

# ── Proxmox (optional — JSON array, one object per node) ───────────────────────
# Token-based auth (recommended):
PROXMOX_NODES=[{"host":"192.168.1.100","user":"root@pam","token_id":"root@pam!scanner","token_secret":"xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx","verify_ssl":false}]
# Multiple nodes example:
# PROXMOX_NODES=[{"host":"pve1.local","user":"root@pam","token_id":"root@pam!scanner","token_secret":"…"},{"host":"pve2.local","user":"root@pam","token_id":"root@pam!scanner","token_secret":"…"}]

# ── Docker (optional — comma-separated TCP socket URLs) ────────────────────────
DOCKER_HOSTS=tcp://10.0.0.2:2375,tcp://10.0.0.3:2375

# ── Scan settings ──────────────────────────────────────────────────────────────
SCAN_INTERVAL_SECONDS=300

# ── Syslog receiver ────────────────────────────────────────────────────────────
SYSLOG_HOST=0.0.0.0
SYSLOG_PORT=514

# ── Optional: nmap supplemental subnet sweeps ──────────────────────────────────
# Comma-separated CIDRs for subnets not managed by OPNsense.
# Requires nmap to be installed on the host.
# NMAP_SUBNETS=10.0.10.0/24,10.0.20.0/24

# ── Optional: SNMP ARP-cache walks ────────────────────────────────────────────
# JSON array of managed switches/routers to walk for additional ARP entries.
# SNMP_HOSTS=[{"host":"10.0.0.1","community":"public","port":161}]

# ── Webhook alerts (optional) ─────────────────────────────────────────────────
# POST target for device_discovered / device_gone events (e.g. Home Assistant, ntfy, Slack).
# ALERT_WEBHOOK_URL=https://hooks.example.com/network-alerts
ALERT_DISAPPEARANCE_THRESHOLD=3

# ── Database ───────────────────────────────────────────────────────────────────
DB_PATH=network_monitor.db
